# Copy to .env and fill in. Never commit .env (it is gitignored).

# ── Where the other two repositories are ───────────────────
# Only used by docker-compose.yml, which pulls in their compose files. The
# defaults assume all three are checked out side by side (the server layout);
# set these if your dev checkout keeps them elsewhere. The other services read
# their OWN .env from their OWN directory — nothing below is passed to them.
#AI_SERVICE_PATH=../DiscordAiService
#SEARCH_SERVICE_PATH=../DsBotSearchService

# ── Discord ────────────────────────────────────────────────
# Bot token from the Discord developer portal.
DISCORD_TOKEN=
# Comma-separated guild IDs to register slash commands in. Guild commands appear
# instantly, so this is the one to set while developing — but they exist ONLY in
# those guilds. LEAVE IT EMPTY to publish to every server the bot joins (Discord
# takes up to an hour to propagate global commands).
DEBUG_GUIID=

# ── Telegram logger (optional) ─────────────────────────────
# Logs are forwarded to this Telegram chat. Leave blank to disable — the bot then
# runs exactly as before, just without the phone notifications.
TG_BOT_SECRET=
TG_CHAT_ID=
# Two independent levels: DEBUG < INFO < WARN < ERROR (OFF silences Telegram
# without unsetting the token). Telegram is for "something broke", not a live
# feed, so it defaults to ERROR; the console defaults to INFO. Set
# TG_LOG_LEVEL=INFO if you want a message on the phone when the bot starts.
LOG_LEVEL=INFO
TG_LOG_LEVEL=ERROR

# ── Redis ──────────────────────────────────────────────────
REDIS_ADDR=127.0.0.1:6379

# ── AI service (agent + TTS) ───────────────────────────────
# DiscordAiService: POST /agent (decisions) and POST /tts (speech).
AI_SERVICE_ADDR=http://127.0.0.1:8000
AI_SERVICE_API_KEY=
# Where playback reports go (POST /playback), if not the same host as /agent.
# Defaults to AI_SERVICE_ADDR. Reports are fire-and-forget: a wrong address here
# loses events silently, so check it against the service before relying on them.
PLAYBACK_SERVICE_ADDR=
# 1/true: log the raw request/response to the AI service ([ai] -> / <-).
AI_DEBUG=0

# ── DJ behaviour ───────────────────────────────────────────
# Insert a spoken DJ comment after every N tracks (default 3).
DJ_BREAK_EVERY=3

# ── Search / media service ─────────────────────────────────
# DsBotSearchService: /search, /stream, /playlist (YouTube).
SEARCH_SERVICE_ADDR=http://127.0.0.1:9000

# ── Speech-to-text ─────────────────────────────────────────
# Command STT — REQUIRED for voice control, there is no local fallback.
# Only utterances the local Vosk gate accepted (someone said the wake word) are
# ever sent off the machine — the gate bounds both the bill and what leaves.
# gpt-4o-mini-transcribe: ~5.3% WER on Russian, $0.003/min, 0.5-1.5s.
OPENAI_API_KEY=
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
# Leave the voice channel after this long with nothing happening — no speech, no
# commands, nothing playing or queued. In seconds; 0 keeps the bot in the channel
# indefinitely. Default 3600.
VOICE_IDLE_TIMEOUT=3600
# Leave once the voice channel has been empty of people for this long, whatever
# the player is doing — music counts as activity above, so without this the bot
# would play to nobody forever. In seconds; 0 disables the check. Default 600.
VOICE_ALONE_TIMEOUT=600

# Wake-word gate (always local): alphacep/kaldi-ru (Vosk, websocket).
VOSK_SERVER_ADDR=ws://127.0.0.1:2700
# 1/true: let Vosk produce the command text too. Off by design — Vosk's small
# model is a wake-word gate, and leaning on it for commands wrecks recognition.
STT_VOSK_ONLY=0
# 1/true: one persistent Vosk connection per speaker, audio streamed as it
# arrives. Finalising an utterance then costs ~260ms flat instead of 600-720ms
# that grows with its length. Falls back automatically if the dial fails.
STT_VOSK_STREAM=0
# Verbosity: 0 silent, 1 commands (default), 2 all transcripts.
STT_LOG_LEVEL=1

# ── The bot's name (wake word) ─────────────────────────────
# Renaming means setting all THREE together. The two lists have opposite jobs:
#   WAKE_WORDS       strict. Decides whether to act. Real forms of the name only.
#   WAKE_WORDS_NEAR  loose.  Decides whether to pay for the accurate model.
#                    Fill it with how the cheap Vosk gate MISHEARS the name —
#                    real unrelated words belong here ("машин" for "марина"),
#                    and must never be copied into WAKE_WORDS, or "включи
#                    Машину времени" wakes the bot for real.
# Matching is substring-based and case-insensitive ("марин" catches марину,
# маринка...). Leave blank to keep the defaults below.
#WAKE_WORDS=марин,марина,маринка,мариночка,мариш,мариша,маришка,marina,marin
#WAKE_WORDS_NEAR=мари,машин,малин,морин,марьин,мурин,marin,machin
# Biases the OpenAI decoder toward the name and the playback vocabulary. Its
# FIRST SENTENCE is also the echo defence: fed silence, the model parrots the
# prompt back as a transcript, and that fake command is dropped by matching this
# sentence — so keep it something no real user would ever say.
#STT_PROMPT=Разговор с ботом Мариной. Марина, включи музыку. Марина, потише.
