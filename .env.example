# Copy to .env and fill in. Never commit .env (it is gitignored).

# ── Discord ────────────────────────────────────────────────
# Bot token from the Discord developer portal.
DISCORD_TOKEN=
# Guild ID for fast command registration in debug mode (config.Debug=true).
DEBUG_GUIID=

# ── Telegram logger (optional) ─────────────────────────────
# Errors/logs are forwarded to this Telegram chat. Leave blank to disable.
TG_BOT_SECRET=
TG_CHAT_ID=

# ── Redis ──────────────────────────────────────────────────
REDIS_ADDR=127.0.0.1:6379

# ── AI service (agent + TTS) ───────────────────────────────
# DiscordAiService: POST /agent (decisions) and POST /tts (speech).
AI_SERVICE_ADDR=http://127.0.0.1:8000
AI_SERVICE_API_KEY=
# 1/true: log the raw request/response to the AI service ([ai] -> / <-).
AI_DEBUG=0

# ── DJ behaviour ───────────────────────────────────────────
# Insert a spoken DJ comment after every N tracks (default 3).
DJ_BREAK_EVERY=3

# ── Search / media service ─────────────────────────────────
# DsBotSearchService: /search, /stream, /playlist (YouTube).
SEARCH_SERVICE_ADDR=http://127.0.0.1:9000

# ── Speech-to-text ─────────────────────────────────────────
# Main STT: onerahmet/openai-whisper-asr-webservice, POST /asr (HTTP).
WHISPER_SERVER_ADDR=http://127.0.0.1:9010
# Wake-word gate / light STT: alphacep/kaldi-ru (Vosk, websocket).
VOSK_SERVER_ADDR=ws://127.0.0.1:2700
# 1/true: use Vosk for the command text too and skip whisper entirely.
STT_VOSK_ONLY=0
# Verbosity: 0 silent, 1 commands (default), 2 all transcripts.
STT_LOG_LEVEL=1
